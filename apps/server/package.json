{
  "name": "@safyr/server",
  "version": "0.1.0",
  "private": true,
  "description": "Safyr backend API (NestJS + Fastify)",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "dotenv -e .env.local -e .env -- tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "auth:generate": "bunx @better-auth/cli generate --config src/auth/auth.schema.ts --output prisma/schema.prisma -y",
    "test": "bun test src/",
    "test:e2e": "dotenv -e .env.test -- bun test ./test/",
    "db:test:push": "dotenv -e .env.test -- prisma db push --accept-data-loss"
  },
  "dependencies": {
    "@better-auth/expo": "^1.6.5",
    "@fastify/cors": "^11.0.1",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.2.2",
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-fastify": "^11.1.3",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@prisma/client-runtime-utils": "^7.7.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.7",
    "@safyr/constants": "workspace:*",
    "@safyr/schemas": "workspace:*",
    "@supabase/supabase-js": "^2.104.1",
    "@tanstack/react-query": "^5.99.1",
    "better-auth": "^1.6.5",
    "dotenv": "^17.4.2",
    "fastify": "^5.2.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.5",
    "@nestjs/schematics": "^11.0.2",
    "@nestjs/testing": "^11.1.19",
    "@types/node": "^22.10.10",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "bun-types": "^1.3.13",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "prisma": "^7.7.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2"
  }
}
