# Root-level env documentation for Safyr.
# Copy the relevant sections into per-app .env files (not committed):
#   apps/server/.env
#   apps/web/.env.local

# ------------------------------------------------------------------------
# apps/server
# ------------------------------------------------------------------------

# Node runtime
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# Database (Neon Postgres). Paste the connection string from console.neon.tech.
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/safyr_dev?sslmode=require

# better-auth core
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-in-local-env
BETTER_AUTH_URL=http://localhost:4000

# Web origin the server trusts (comma-separated allowlist).
ALLOWED_ORIGINS=http://localhost:3000

# Email (optional in dev; if unset, magic-link URLs are only console-logged).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Safyr <no-reply@safyr.app>"

# Captcha (disabled in dev by default).
CAPTCHA_PROVIDER=
CAPTCHA_SECRET_KEY=

# ------------------------------------------------------------------------
# apps/web
# ------------------------------------------------------------------------

NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MAPBOX_TOKEN=
